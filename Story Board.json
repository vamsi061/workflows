{
  "name": "Story Board",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst BASE_URL = 'http://host.docker.internal:8080';\nconst output = {};\n\n// Helper to extract path safely\nfunction extractPath(fullUrl) {\n  const pathIndex = fullUrl.indexOf('/', 8); \n  // skip \"http://\"\n  return pathIndex !== -1 ? fullUrl.substring(pathIndex) : '';\n}\n\n// Get image keys sorted numerically\nconst imageKeys = Object.keys(input)\n  .filter(key => key.startsWith('image_'))\n  .sort((a, b) => Number(a.split('_')[1]) - Number(b.split('_')[1]));\n\n// Get audio keys sorted numerically\nconst audioKeys = Object.keys(input)\n  .filter(key => key.startsWith('audio_'))\n  .sort((a, b) => Number(a.split('_')[1]) - Number(b.split('_')[1]));\n\n// Process images\nimageKeys.forEach(key => {\n  const index = key.split('_')[1];\n  const imageUrl = input[key] && input[key].image_url;\n\n  if (imageUrl) {\n    const path = extractPath(imageUrl);\n    output[`Image ${index}`] = BASE_URL + path;\n  }\n});\n\n// Process audio\naudioKeys.forEach(key => {\n  const index = key.split('_')[1];\n  const audioUrl = input[key] && input[key].file_url;\n\n  if (audioUrl) {\n    const path = extractPath(audioUrl);\n    output[`Audio ${index}`] = BASE_URL + path;\n  }\n});\n\n// Add constant base_url\noutput.base_url = BASE_URL;\n\nreturn [{ json: output }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        8624,
        26064
      ],
