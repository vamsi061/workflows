    {
      "parameters": {
        "jsCode": "// Get uploaded files from form\nconst inputItem = $input.first();\nconst json = inputItem.json || {};\nconst binaryData = inputItem.binary || {};\n\nconst allKeys = Object.keys(json).join(', ');\n\n// Get audio script\nconst audioScript =\n  json['Complete Audio Script'] ||\n  json['Story Audio Script'] ||\n  json['complete_audio_script'];\n\nif (!audioScript) {\n  throw new Error(`Audio script not found. Form JSON keys: ${allKeys}`);\n}\n\n// Collect ALL binary files\nconst binaryKeys = Object.keys(binaryData);\n\nif (binaryKeys.length === 0) {\n  throw new Error('No images found in binary data');\n}\n\nconst items = [];\n\nbinaryKeys.forEach((key, index) => {\n  const file = binaryData[key];\n  const imageIndex = index + 1;\n\n  const targetPath = `/home/node/.n8n-files/images/${imageIndex}.png`;\n\n  items.push({\n    json: {\n      image_index: imageIndex,\n      filePath: targetPath,\n      audioScript: audioScript,\n      originalFileName: file.fileName || `image_${imageIndex}`,\n      binaryFieldName: key\n    },\n    binary: {\n      data: file\n    }\n  });\n});\n\nreturn items;"
      },
