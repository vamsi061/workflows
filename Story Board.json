      "id": "e6dc05b5-928e-4ef6-9bfd-c7c60ebca65a",
      "name": "Read Image File"
    },
    {
      "parameters": {
        "jsCode": "// After aggregate, get audioScript from the first item's data\nconst items = $input.all();\n\n// The aggregate node wraps items in a 'data' array\n// Get the audioScript from the first original item\nlet audioScript;\n\nif (items.length > 0 && items[0].json.data && Array.isArray(items[0].json.data)) {\n  // Aggregate output format\n  const firstOriginalItem = items[0].json.data[0];\n  audioScript = firstOriginalItem.audioScript;\n} else {\n  // Direct format (fallback)\n  audioScript = items[0].json.audioScript || items[0].json['Complete Audio Script'];\n}\n\nif (!audioScript) {\n  const availableKeys = Object.keys(items[0].json).join(', ');\n  throw new Error(`No audio script found. Available keys: ${availableKeys}`);\n}\n\n// Split by blank lines (double newline)\nconst segments = audioScript\n  .split(/\\n\\s*\\n/)\n  .map(s => s.trim())\n  .filter(s => s.length > 0);\n\n// Create output with audio_1, audio_2, etc.\nconst output = {};\nsegments.forEach((segment, index) => {\n  output[`audio_${index + 1}`] = segment;\n});\n\nreturn [{ json: output }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        7920,
        27216
      ],
      "id": "1257c250-1db6-48f2-9c29-b8f86ef341df",
      "name": "Split Audio Scripts"
    },
    {
      "parameters": {
        "jsCode": "// Get the number of audio scripts\nconst audioCount = Object.keys($input.first().json).filter(key => key.startsWith('audio_')).length;\n\n// We have 20 images saved (1.png through 20.png)\nconst imageCount = 20;\n\nconst items = [];\n\n// Generate items for each audio segment\nfor (let i = 1; i <= audioCount; i++) {\n  let imageIndex;\n  \n  if (i <= imageCount) {\n    // Use images 1-20 for audio 1-20\n    imageIndex = i;\n  } else {\n    // Reuse from the end: audio 21 -> image 19, audio 22 -> image 20\n    const overflow = i - imageCount;\n    imageIndex = imageCount - overflow + 1;\n  }\n  \n  items.push({\n    json: {\n      image_index: i,\n      actual_image_file: imageIndex,\n      filePath: `/home/node/.n8n-files/images/${imageIndex}.png`,\n      fileName: `${imageIndex}.png`\n    }\n  });\n}\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        8384,
        27232
      ],
      "id": "77f4d0aa-c5e3-44c1-a0cb-3f5eed364404",
      "name": "Generate Image Items"
