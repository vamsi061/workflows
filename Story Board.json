    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\nconst BASE_URL = 'http://host.docker.internal:8080';\nconst output = {};\n\n// Get image keys sorted numerically\nconst imageKeys = Object.keys(input)\n  .filter(key => key.startsWith('image_'))\n  .sort((a, b) => Number(a.split('_')[1]) - Number(b.split('_')[1]));\n\n// Get audio keys sorted numerically\nconst audioKeys = Object.keys(input)\n  .filter(key => key.startsWith('audio_'))\n  .sort((a, b) => Number(a.split('_')[1]) - Number(b.split('_')[1]));\n\n// Process images (DO NOT MODIFY URL)\nimageKeys.forEach(key => {\n  const index = key.split('_')[1];\n  const imageUrl = input[key] && input[key].image_url;\n\n  if (imageUrl) {\n    output[`Image ${index}`] = imageUrl;\n  }\n});\n\n// Process audio (DO NOT MODIFY URL)\naudioKeys.forEach(key => {\n  const index = key.split('_')[1];\n  const audioUrl = input[key] && input[key].file_url;\n\n  if (audioUrl) {\n    output[`Audio ${index}`] = audioUrl;\n  }\n});\n\n// Add constant base_url separately\noutput.base_url = BASE_URL;\n\nreturn [{ json: output }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        7600,
        28144
