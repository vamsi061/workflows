      "parameters": {
        "jsCode": "// Prepare items for Kokoro TTS API\nconst audioData = $input.first().json;\n\n// Get all audio segments\nconst audioKeys = Object.keys(audioData).filter(key => key.startsWith('audio_')).sort();\n\nconst items = [];\naudioKeys.forEach((key, index) => {\n  items.push({\n    json: {\n      audio_index: index + 1,\n      audio_script: audioData[key],\n      input: audioData[key]  // Required by Kokoro TTS API\n    }\n  });\n});\n\nreturn items;"
      },
